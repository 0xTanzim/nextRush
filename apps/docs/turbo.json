{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": [],
      "inputs": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "content/**/*.mdx",
        "content/**/*.json",
        "next.config.ts",
        "tsconfig.json"
      ]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        ".next/**",
        "out/**",
        "dist/**",
        "!.next/cache/**",
        "!.next/dev/**",
        "!.next/build/**",
        "!.next/diagnostics/**",
        "!.next/server/chunks/**",
        "!.next/server/pages/**"
      ],
      "inputs": ["src/**", "content/**", "next.config.ts", "tsconfig.json"],
      "env": ["NEXTRUSH_DOCS_BASE_PATH"]
    }
  }
}
