{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@nextrush/types": ["packages/types/src"],
      "@nextrush/core": ["packages/core/src"],
      "@nextrush/router": ["packages/router/src"],
      "@nextrush/adapter-node": ["packages/adapters/node/src"]
    }
  },
  "references": [
    { "path": "packages/types" },
    { "path": "packages/core" },
    { "path": "packages/router" },
    { "path": "packages/adapters/node" }
  ],
  "include": [],
  "exclude": ["node_modules", "dist", "_archive"]
}
