{
  "name": "nextrush-monorepo",
  "version": "0.0.1",
  "private": true,
  "description": "NextRush v3 - Minimal, modular, high-performance Node.js framework",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:coverage": "turbo run test:coverage",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "clean:modules": "bash scripts/clean-modules.sh",
    "update:all": "bash scripts/update-all.sh",
    "fresh": "bash scripts/fresh-install.sh",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "docs:validate": "tsx scripts/docs/build-docs.ts",
    "docs:validate:strict": "tsx scripts/docs/build-docs.ts --strict",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo run build && changeset publish --provenance",
    "prepare": "turbo run build",
    "create": "node packages/create-nextrush/bin/create-nextrush.js"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.29.8",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "turbo": "^2.8.12",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xTanzim/nextrush.git"
  },
  "homepage": "https://github.com/0xTanzim/nextrush#readme",
  "bugs": {
    "url": "https://github.com/0xTanzim/nextrush/issues"
  },
  "author": {
    "name": "Tanzim Hossain",
    "email": "tanzimhossain2@gmail.com",
    "url": "https://github.com/0xTanzim"
  },
  "license": "MIT"
}
