{
  "name": "@nextrush/dev",
  "version": "3.0.0",
  "description": "Development server and build tools for NextRush - multi-runtime support",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "nextrush": "./bin/nextrush.js",
    "nextrush-dev": "./bin/nextrush-dev.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "nextrush",
    "dev",
    "development",
    "build",
    "watch",
    "cli",
    "multi-runtime",
    "node",
    "bun",
    "deno"
  ],
  "author": {
    "name": "Tanzim Hossain",
    "email": "tanzimhossain2@gmail.com",
    "url": "https://github.com/0xTanzim"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xTanzim/nextrush.git",
    "directory": "packages/dev"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.18",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "access": "public"
  }
}
