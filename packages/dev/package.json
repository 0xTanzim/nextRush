{
  "name": "@nextrush/dev",
  "version": "3.0.0-alpha.1",
  "description": "Development server for NextRush - powered by tsx",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "nextrush-dev": "./bin/nextrush-dev.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "nextrush",
    "dev",
    "development",
    "watch",
    "tsx"
  ],
  "author": "NextRush Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/0xtanzim/nextrush.git",
    "directory": "packages/dev"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@swc-node/register": "^1.10.9",
    "@swc/core": "^1.11.1",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3"
  }
}
