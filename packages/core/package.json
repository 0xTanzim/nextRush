{
  "name": "@nextrush/core",
  "version": "3.0.3",
  "description": "Core functionality for NextRush framework - Application, Context, Middleware",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ignore-pattern '**/__tests__/**'",
    "lint:fix": "eslint src --fix --ignore-pattern '**/__tests__/**'",
    "clean": "rm -rf dist .turbo"
  },
  "keywords": [
    "nextrush",
    "framework",
    "http",
    "server",
    "middleware",
    "context"
  ],
  "author": {
    "name": "Tanzim Hossain",
    "email": "tanzimhossain2@gmail.com",
    "url": "https://github.com/0xTanzim"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xTanzim/nextRush.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/0xTanzim/nextRush/issues"
  },
  "homepage": "https://github.com/0xTanzim/nextRush/tree/main/packages/core#readme",
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@nextrush/errors": "workspace:*",
    "@nextrush/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "sideEffects": false
}
