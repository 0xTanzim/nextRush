{
  "name": "@nextrush/static",
  "version": "3.0.3",
  "description": "High-performance static file serving middleware for NextRush",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "nextrush",
    "static",
    "files",
    "serve",
    "middleware",
    "http",
    "server"
  ],
  "author": {
    "name": "Tanzim Hossain",
    "email": "tanzimhossain2@gmail.com",
    "url": "https://github.com/0xTanzim"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xTanzim/nextRush.git",
    "directory": "packages/plugins/static"
  },
  "bugs": {
    "url": "https://github.com/0xTanzim/nextRush/issues"
  },
  "homepage": "https://github.com/0xTanzim/nextRush/tree/main/packages/plugins/static#readme",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@nextrush/types": "workspace:^"
  },
  "devDependencies": {
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "@nextrush/core": "workspace:^"
  },
  "peerDependenciesMeta": {
    "@nextrush/core": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
