{
  "name": "@nextrush/logger",
  "version": "3.0.1",
  "description": "Request logging middleware for NextRush - wraps @nextrush/log",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "nextrush",
    "logger",
    "logging",
    "middleware",
    "request-logging"
  ],
  "author": {
    "name": "Tanzim Hossain",
    "email": "tanzimhossain2@gmail.com",
    "url": "https://github.com/0xTanzim"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xTanzim/nextRush.git",
    "directory": "packages/plugins/logger"
  },
  "dependencies": {
    "@nextrush/log": "^0.2.1",
    "@nextrush/types": "workspace:^"
  },
  "devDependencies": {
    "@nextrush/core": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "@nextrush/core": "workspace:^"
  },
  "peerDependenciesMeta": {
    "@nextrush/core": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/0xTanzim/nextRush/tree/main/packages/plugins/logger#readme",
  "sideEffects": false
}
