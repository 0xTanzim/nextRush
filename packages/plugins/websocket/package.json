{
  "name": "@nextrush/websocket",
  "version": "3.0.0",
  "description": "WebSocket plugin for NextRush with rooms, broadcasting, and simple DX",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nextrush/types": "workspace:^"
  },
  "peerDependencies": {
    "ws": "^8.0.0"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4",
    "ws": "^8.20.0"
  },
  "keywords": [
    "nextrush",
    "websocket",
    "ws",
    "realtime",
    "rooms",
    "channels"
  ],
  "author": {
    "name": "Tanzim Hossain",
    "email": "tanzimhossain2@gmail.com",
    "url": "https://github.com/0xTanzim"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xTanzim/nextRush.git",
    "directory": "packages/plugins/websocket"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/0xTanzim/nextRush/tree/main/packages/plugins/websocket#readme",
  "sideEffects": false
}
