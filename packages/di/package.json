{
  "name": "@nextrush/di",
  "version": "3.0.0-alpha.2",
  "description": "Lightweight dependency injection container for NextRush",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "tsyringe": "^4.8.0",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@nextrush/types": "workspace:*",
    "rimraf": "^5.0.5",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "keywords": [
    "nextrush",
    "di",
    "dependency-injection",
    "ioc",
    "container",
    "typescript"
  ],
  "author": "NextRush Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/0xtanzim/nextrush.git",
    "directory": "packages/di"
  },
  "bugs": {
    "url": "https://github.com/0xtanzim/nextrush/issues"
  },
  "homepage": "https://github.com/0xtanzim/nextrush/tree/main/packages/di#readme"
}
