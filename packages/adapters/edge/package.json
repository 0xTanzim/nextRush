{
  "name": "@nextrush/adapter-edge",
  "version": "3.0.0",
  "description": "Edge runtime adapter for NextRush (Cloudflare Workers, Vercel Edge, etc.)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ignore-pattern '**/__tests__/**'",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nextrush/core": "workspace:^",
    "@nextrush/errors": "workspace:^",
    "@nextrush/runtime": "workspace:^",
    "@nextrush/types": "workspace:^"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "keywords": [
    "nextrush",
    "adapter",
    "edge",
    "cloudflare",
    "workers",
    "vercel",
    "http",
    "framework"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xTanzim/nextRush.git",
    "directory": "packages/adapters/edge"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/0xTanzim/nextRush/tree/main/packages/adapters/edge#readme",
  "engines": {
    "node": ">=22.0.0"
  },
  "author": {
    "name": "Tanzim Hossain",
    "email": "tanzimhossain2@gmail.com",
    "url": "https://github.com/0xTanzim"
  },
  "sideEffects": false
}
