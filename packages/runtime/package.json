{
  "name": "@nextrush/runtime",
  "version": "3.0.1",
  "description": "Runtime detection and cross-runtime abstractions for NextRush",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ignore-pattern '**/__tests__/**'",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nextrush/errors": "workspace:*",
    "@nextrush/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "keywords": [
    "nextrush",
    "runtime",
    "detection",
    "bun",
    "deno",
    "edge",
    "node"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xTanzim/nextRush.git",
    "directory": "packages/runtime"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/0xTanzim/nextRush/tree/main/packages/runtime#readme",
  "author": {
    "name": "Tanzim Hossain",
    "email": "tanzimhossain2@gmail.com",
    "url": "https://github.com/0xTanzim"
  },
  "sideEffects": false
}
