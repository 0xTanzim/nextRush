{
  "name": "nextrush",
  "version": "3.0.0",
  "description": "Minimal, modular, blazing fast Node.js framework",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./class": {
      "types": "./dist/class.d.ts",
      "import": "./dist/class.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "framework",
    "web",
    "http",
    "server",
    "minimal",
    "fast",
    "typescript",
    "nodejs",
    "backend",
    "api",
    "rest"
  ],
  "author": {
    "name": "Tanzim Hossain",
    "email": "tanzimhossain2@gmail.com",
    "url": "https://github.com/0xTanzim"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xTanzim/nextrush.git",
    "directory": "packages/nextrush"
  },
  "homepage": "https://nextrush.dev",
  "bugs": {
    "url": "https://github.com/0xTanzim/nextrush/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "./dist/class.js"
  ],
  "dependencies": {
    "@nextrush/adapter-node": "workspace:*",
    "@nextrush/controllers": "workspace:*",
    "@nextrush/core": "workspace:*",
    "@nextrush/decorators": "workspace:*",
    "@nextrush/di": "workspace:*",
    "@nextrush/errors": "workspace:*",
    "@nextrush/router": "workspace:*",
    "@nextrush/types": "workspace:*",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@nextrush/body-parser": "workspace:*",
    "@nextrush/compression": "workspace:*",
    "@nextrush/cors": "workspace:*",
    "@nextrush/helmet": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
