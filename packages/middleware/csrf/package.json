{
  "name": "@nextrush/csrf",
  "version": "3.0.0",
  "description": "CSRF protection middleware for NextRush — Signed Double-Submit Cookie pattern with HMAC-SHA256",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ignore-pattern 'src/__tests__/'",
    "clean": "rimraf dist"
  },
  "keywords": [
    "nextrush",
    "middleware",
    "csrf",
    "xsrf",
    "security",
    "double-submit-cookie",
    "hmac",
    "cross-site-request-forgery"
  ],
  "author": {
    "name": "Tanzim Hossain",
    "email": "tanzimhossain2@gmail.com",
    "url": "https://github.com/0xTanzim"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xTanzim/nextrush.git",
    "directory": "packages/middleware/csrf"
  },
  "bugs": {
    "url": "https://github.com/nextrush/nextrush/issues"
  },
  "homepage": "https://github.com/nextrush/nextrush#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@nextrush/types": "workspace:^"
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "sideEffects": false
}
