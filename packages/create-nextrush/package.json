{
  "name": "create-nextrush",
  "version": "3.0.2",
  "description": "Create a new NextRush project with one command",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "create-nextrush": "./bin/create-nextrush.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "scripts": {
    "prepublishOnly": "npx tsup",
    "build": "tsup",
    "clean": "rm -rf dist",
    "lint": "eslint src --max-warnings 0 --ignore-pattern '**/__tests__/**'",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "nextrush",
    "create",
    "scaffold",
    "cli",
    "framework",
    "typescript",
    "nodejs"
  ],
  "author": {
    "name": "Tanzim Hossain",
    "email": "tanzimhossain2@gmail.com",
    "url": "https://github.com/0xTanzim"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xTanzim/nextRush.git",
    "directory": "packages/create-nextrush"
  },
  "homepage": "https://github.com/0xTanzim/nextRush/tree/main/packages/create-nextrush#readme",
  "bugs": {
    "url": "https://github.com/0xTanzim/nextRush/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
