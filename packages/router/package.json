{
  "name": "@nextrush/router",
  "version": "3.0.0-alpha.1",
  "description": "High-performance radix tree router for NextRush",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nextrush/types": "workspace:*"
  },
  "devDependencies": {
    "@nextrush/core": "workspace:*",
    "typescript": "^5.9.3",
    "tsup": "^8.5.1"
  },
  "peerDependencies": {
    "@nextrush/core": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@nextrush/core": {
      "optional": true
    }
  },
  "keywords": [
    "nextrush",
    "router",
    "radix-tree",
    "http",
    "framework"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  }
}
