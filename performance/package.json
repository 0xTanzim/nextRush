{
  "name": "nextrush-performance-benchmarks",
  "version": "2.0.0",
  "description": "Enterprise-grade performance benchmarks for NextRush v2 vs Express, Fastify, Koa, and Hono",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "pnpm install",
    "bench:all": "node scripts/benchmark-all.js",
    "bench:all:quick": "node scripts/benchmark-all.js --quick",
    "bench:nextrush": "node scripts/nextrush-benchmark.js",
    "bench:nextrush:quick": "node scripts/nextrush-benchmark.js --quick",
    "bench:nextrush:compare": "node scripts/nextrush-compare.js",
    "bench:nextrush:history": "node scripts/nextrush-compare.js --history",
    "bench:nextrush:trend": "node scripts/nextrush-compare.js --trend",
    "analyze": "node scripts/analyze.js",
    "clean": "rm -rf results/*.json results/*.txt results/*.md",
    "clean:nextrush": "rm -rf results/nextrush",
    "clean:comparison": "rm -rf results/comparison",
    "clean:all": "rm -rf results"
  },
  "devDependencies": {
    "@hono/node-server": "^1.13.1",
    "autocannon": "^8.0.0",
    "express": "^5.1.0",
    "fastify": "^5.6.1",
    "hono": "^4.6.0",
    "koa": "^3.0.1",
    "koa-bodyparser": "^4.4.1",
    "koa-router": "^14.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
