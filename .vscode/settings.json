{
  "js/ts.tsdk.path": "./node_modules/typescript/lib",
  "js/ts.tsdk.promptToUseWorkspaceVersion": true,
  "js/ts.tsserver.useSyntaxServer": "auto",
  "js/ts.preferences.importModuleSpecifier": "non-relative",
  "js/ts.tsserver.experimental.enableProjectDiagnostics": false,
  "js/ts.preferences.includePackageJsonAutoImports": "on",
  "js/ts.suggest.autoImports": true,
  "js/ts.workspaceSymbols.scope": "allOpenProjects",
  "js/ts.inlayHints.parameterNames.enabled": "literals",
  "js/ts.inlayHints.functionLikeReturnTypes.enabled": true,
  "js/ts.inlayHints.variableTypes.enabled": false,


  // NextRush-specific configurations
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/.git/**": true,
    "**/NextRush_Src_Old/**": true
  },
  "search.exclude": {
    "**/NextRush_Src_Old/**": true,
    "**/dist/**": true
  },

  // Plugin development optimizations
  "editor.quickSuggestions": {
    "other": true,
    "comments": false,
    "strings": true
  },
  "editor.suggest.snippetsPreventQuickSuggestions": false,
  "editor.parameterHints.enabled": true,
  "editor.codeLens": true,

  // Performance optimizations
  "files.hotExit": "off",
  "workbench.editor.restoreViewState": false,
  "workbench.editor.enablePreview": false,
  "copilot.conversation.persistState": false,

  // Code formatting
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit",
    "source.fixAll.eslint": "explicit"
  },

  // File associations for NextRush
  "files.associations": {
    "*.nextrush": "typescript",
    "*.plugin.ts": "typescript"
  },

  // IntelliSense optimizations
  "js/ts.suggest.includeAutomaticOptionalChainCompletions": true,
  "js/ts.suggest.includeCompletionsForImportStatements": true,
  "js/ts.suggest.paths": true,

  // Error highlighting
  "js/ts.validate.enable": true,
  "js/ts.reportStyleChecksAsWarnings": true,

  // Plugin-specific settings
  "emmet.includeLanguages": {
    "typescript": "html"
  },

  // NextRush framework development
  "nextRush.pluginValidation": true,
  "nextRush.typeInference": "strict",
  "nextRush.autoImports": true,

  // Development server settings
  "liveServer.settings.donotShowInfoMsg": true,
  "liveServer.settings.donotVerifyTags": true,

  // Git configuration
  "git.ignoreLimitWarning": true,
  "git.autofetch": true,

  // Terminal configuration
  "terminal.integrated.defaultProfile.linux": "zsh",
  "terminal.integrated.profiles.linux": {
    "zsh": {
      "path": "/usr/bin/zsh",
      "args": ["-l"]
    }
  },
  "chat.agentSessionsViewLocation": "view",
  "inlineChat.notebookAgent": true,
  "github.copilot.chat.agent.thinkingTool": true,
  "terminal.integrated.tabs.defaultColor": "terminal.ansiGreen",
  "github.copilot.chat.codesearch.enabled": true,
  "github.copilot.chat.scopeSelection": true,
  "github.copilot.chat.editor.temporalContext.enabled": true,
  "github.copilot.chat.edits.temporalContext.enabled": true,
  "github.copilot.chat.enableRetryAfterFilteredResponse": true,
  "github.copilot.chat.generateTests.codeLens": true,
  "github.copilot.chat.languageContext.typescript.enabled": true,
  "github.copilot.chat.newWorkspace.useContext7": true,
  "github.copilot.chat.notebook.followCellExecution.enabled": true

}
